{
  "name": "pos_inventur",
  "version": "1.0.0",
  "description": "Inventur - Inventory & POS Management System",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run watch:css\"",
    "start": "node server/index.js",
    "server": "node server/index.js",
    "build:css": "tailwindcss -i ./assets/css/tailwind.input.css -o ./assets/css/tailwind.css --minify",
    "watch:css": "tailwindcss -i ./assets/css/tailwind.input.css -o ./assets/css/tailwind.css --watch",
    "db:setup": "node db/db-setup.js",
    "db:seed": "node db/db-seed.js",
    "db:init": "node db/db-setup.js && node db/db-seed.js",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "dotenv": "^17.4.2",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.0"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "bcryptjs": "^3.0.3",
    "browser-sync": "^3.0.4",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.3"
  }
}
